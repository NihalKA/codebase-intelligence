# ─────────────────────────────────────────────────────────────
# .env.example — copy this to .env and fill in real values
# NEVER commit .env to Git
# ─────────────────────────────────────────────────────────────

# Your server's internal IP address
SERVER_IP=YOUR_SERVER_IP

# ── Neo4j ──────────────────────────────────────────────────────
NEO4J_AUTH=neo4j/CHANGE_ME_STRONG_PASSWORD
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Qdrant ─────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
# Leave blank for local-only Qdrant (no authentication required on a private network)
QDRANT_API_KEY=CHANGE_ME_OR_LEAVE_BLANK

# ── Ollama ─────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=deepseek-coder:6.7b

# ── MinIO ──────────────────────────────────────────────────────
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MINIO_ENDPOINT=localhost:9000
# Bucket where generated service documentation is stored
MINIO_DOCS_BUCKET=service-docs
# ── Sourcegraph ────────────────────────────────────────────
# Sourcegraph OSS runs locally on port 7080 — used by the indexer for cross-repo symbol search
SOURCEGRAPH_URL=http://localhost:7080
SOURCEGRAPH_TOKEN=sgp_CHANGE_ME
# ── GitHub ─────────────────────────────────────────────────────
# Fine-grained PAT — read-only, scoped to target repos only
GITHUB_TOKEN=github_pat_CHANGE_ME

# ── Optional: Documentation publishing (Phase 4) ───────────────
# Leave blank to disable — MinIO is always the primary destination

# Push generated docs to Confluence (leave blank to disable)
CONFLUENCE_URL=
CONFLUENCE_TOKEN=
CONFLUENCE_SPACE_KEY=

# Commit generated docs back to each repo (true/false, default false)
COMMIT_DOCS_TO_REPO=false
